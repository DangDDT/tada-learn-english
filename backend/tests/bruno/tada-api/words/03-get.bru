get {
  url: {{base_url}}/api/v1/words/{{word_id}}
  auth: bearer {{access_token}}
}

docs {
  Get single word by id.
}

tests {
  function onResponse(req, res) {
  expect(res.status).to.equal(200);
expect(res.body.data.id).to.equal(bru.getVar('word_id'));
expect(res.body.data.word).to.equal('serendipity');
  }
}
