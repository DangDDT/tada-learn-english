post {
  url: {{base_url}}/api/v1/words
  body: json
  auth: bearer {{access_token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "word": "duplicate-test",
    "meaning": "dup"
  }
}

docs {
  First create of 'duplicate-test'. Expect 201.
  Second create (after:response script) Expect 409.
}

tests {
  function onResponse(req, res) {
  expect(res.status).to.equal(201);
expect(res.body.success).to.equal(true);
  }
}

script:post-response {
  // Bruno CLI cannot send nested requests in post-response scripts.
  // This test only validates the first create. Duplicate conflict coverage
  // is handled by Postman parity / manual check.
}
