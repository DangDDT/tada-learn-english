post {
  url: {{base_url}}/api/v1/auth/forgot-password
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{test_email}}"
  }
}

docs {
  Request password reset. Always 200 (avoid email enumeration).
}

tests {
  function onResponse(req, res) {
  expect(res.status).to.equal(200);
expect(res.body.success).to.equal(true);
expect(res.body.data.message).to.match(/reset link/i);
  }
}
