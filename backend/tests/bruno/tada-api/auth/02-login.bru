post {
  url: {{base_url}}/api/v1/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{test_email}}",
    "password": "{{test_password}}"
  }
}

docs {
  Login with registered credentials. Saves access_token + refresh_token.
}

tests {
  function onResponse(req, res) {
  expect(res.status).to.equal(200);
expect(res.body.success).to.equal(true);
expect(res.body.data.access_token).to.be.a('string');
expect(res.body.data.refresh_token).to.be.a('string');
  }
}

script:post-response {
  const body = res.getBody();
  if (body && body.data) {
    bru.setVar("access_token", body.data.access_token);
    bru.setVar("refresh_token", body.data.refresh_token);
  }
}
